# ─── Pastel Diary — Backend Environment Variables ───────────────

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/pastel-diary?retryWrites=true&w=majority

# Your deployed Vercel frontend URL (for CORS)
FRONTEND_URL=https://pastel-diary-roan.vercel.app

# Port (Railway/Render set this automatically)
PORT=3001
