# ─── Pastel Diary — Backend Environment Variables ───────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your Google Gemini API key (from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIza...

# Frontend origin allowed by CORS (your Vercel URL after deployment)
FRONTEND_URL=https://your-app.vercel.app

# Port the proxy server listens on (Railway sets this automatically)
PORT=3001
